# QuantFlow — Kubernetes Secret template
# DO NOT commit real values. Use this template and inject via CI/CD:
#
#   kubectl create secret generic quantflow-secrets \
#     --namespace=quantflow \
#     --from-literal=DATABASE_URL="postgresql+asyncpg://..." \
#     --from-literal=REDIS_URL="redis://..." \
#     --from-literal=JWT_SECRET_KEY="..." \
#     --from-literal=STRIPE_SECRET_KEY="..." \
#     --from-literal=STRIPE_WEBHOOK_SECRET="..." \
#     --from-literal=OPENAI_API_KEY="..." \
#     --from-literal=ANTHROPIC_API_KEY="..." \
#     --from-literal=PERPLEXITY_API_KEY="..." \
#     --from-literal=ALPHA_VANTAGE_API_KEY="..." \
#     --from-literal=POLYGON_API_KEY="..." \
#     --from-literal=FRED_API_KEY="..." \
#     --from-literal=SENTRY_DSN="..." \
#     --from-literal=PAGERDUTY_INTEGRATION_KEY="..." \
#     --from-literal=SLACK_WEBHOOK_URL="..."
#
# For GitOps workflows consider using:
#   - Sealed Secrets (bitnami-labs/sealed-secrets)
#   - External Secrets Operator (with AWS SSM / GCP Secret Manager / Vault)

apiVersion: v1
kind: Secret
metadata:
  name: quantflow-secrets
  namespace: quantflow
  labels:
    app.kubernetes.io/name: quantflow
type: Opaque
stringData:
  DATABASE_URL: "REPLACE_WITH_ACTUAL_VALUE"
  REDIS_URL: "REPLACE_WITH_ACTUAL_VALUE"
  JWT_SECRET_KEY: "REPLACE_WITH_ACTUAL_VALUE"
  STRIPE_SECRET_KEY: "REPLACE_WITH_ACTUAL_VALUE"
  STRIPE_WEBHOOK_SECRET: "REPLACE_WITH_ACTUAL_VALUE"
  OPENAI_API_KEY: "REPLACE_WITH_ACTUAL_VALUE"
  ANTHROPIC_API_KEY: "REPLACE_WITH_ACTUAL_VALUE"
  PERPLEXITY_API_KEY: "REPLACE_WITH_ACTUAL_VALUE"
  ALPHA_VANTAGE_API_KEY: "REPLACE_WITH_ACTUAL_VALUE"
  POLYGON_API_KEY: "REPLACE_WITH_ACTUAL_VALUE"
  FRED_API_KEY: "REPLACE_WITH_ACTUAL_VALUE"
  SENTRY_DSN: "REPLACE_WITH_ACTUAL_VALUE"
  PAGERDUTY_INTEGRATION_KEY: "REPLACE_WITH_ACTUAL_VALUE"
  SLACK_WEBHOOK_URL: "REPLACE_WITH_ACTUAL_VALUE"
