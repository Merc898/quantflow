# ============================================================
# QuantFlow — Environment Variables Reference
# ============================================================
# This file is safe to commit to version control.
# Copy it to .env and fill in real values for local dev.
#
# DO NOT put actual secrets in this file.
# ============================================================

# ------------------------------------------------------------
# Application
# ------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=false

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://quantflow:quantflow@localhost:5432/quantflow
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------
# Data Provider API Keys
# ------------------------------------------------------------
ALPHA_VANTAGE_API_KEY=
POLYGON_API_KEY=
FRED_API_KEY=
QUANDL_API_KEY=

# ------------------------------------------------------------
# LLM API Keys
# ------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=

# ------------------------------------------------------------
# Authentication — JWT
# ------------------------------------------------------------
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ------------------------------------------------------------
# Stripe Billing
# ------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ------------------------------------------------------------
# MLflow
# ------------------------------------------------------------
MLFLOW_TRACKING_URI=file:./mlruns

# ------------------------------------------------------------
# Caching TTLs (seconds)
# ------------------------------------------------------------
MODEL_CACHE_TTL_SECONDS=300
FEATURE_CACHE_TTL_SECONDS=300
SIGNAL_CACHE_TTL_SECONDS=60

# ------------------------------------------------------------
# Rate limiting (requests per day, per tier)
# ------------------------------------------------------------
RATE_LIMIT_FREE_REQUESTS_PER_DAY=100
RATE_LIMIT_PREMIUM_REQUESTS_PER_DAY=1000
RATE_LIMIT_INSTITUTIONAL_REQUESTS_PER_DAY=10000

# ------------------------------------------------------------
# Backtesting cost assumptions
# ------------------------------------------------------------
BACKTEST_COMMISSION_PER_SHARE=0.005
BACKTEST_SLIPPAGE_BPS=5.0
BACKTEST_MARKET_IMPACT_COEFFICIENT=10.0
